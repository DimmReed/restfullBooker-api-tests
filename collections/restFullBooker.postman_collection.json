            "exec": [
              "pm.test(\"Status code should be 200\", function() {\r",
              "    pm.expect(pm.response.code).to.equal(200);\r",
              "    pm.response.to.have.status(\"OK\");\r",
              "\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.expect(response).to.be.an('array');\r",
              "    response.forEach(booking => {\r",
              "        pm.expect(booking.bookingid).to.exist;\r",
              "        pm.expect(booking.bookingid).to.be.a('number');\r",
              "    });\r",
              "\r",
              "    pm.response.to.have.header('Report-To');\r",
              "    pm.response.to.have.header('Date');\r",
              "    pm.response.to.have.header('Content-Length');\r",
              "\r",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json; charset=utf-8');\r",
              "    pm.expect(pm.response.responseTime).to.be.within(50, 1000);\r",
              "\r",
              "    \r",
              "\r",
              "\r",
              "\r",
              "});\r",
              ""
